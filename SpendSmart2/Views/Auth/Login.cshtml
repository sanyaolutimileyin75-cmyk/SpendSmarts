@model SpendSmart2.Models.LoginViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Login";
}

<div class="auth-card">
    <div class="auth-logo">
        <h1>Spend<span>Smart</span></h1>
        <p>Sign in to manage your finances</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values
            .SelectMany(v => v.Errors))
            {
                <div><i class="fas fa-exclamation-circle me-2"></i>@error.ErrorMessage</div>
            }
        </div>
    }

    <form asp-action="Login" asp-controller="Auth" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">
                <i class="fas fa-envelope me-2"></i>Email Address
            </label>
            <input asp-for="Email"
                   class="form-control"
                   placeholder="Enter your email" />
            <span asp-validation-for="Email" class="text-danger" style="font-size:12px"></span>
        </div>

        <div class="mb-4">
            <label class="form-label">
                <i class="fas fa-lock me-2"></i>Password
            </label>
            <input asp-for="Password"
                   class="form-control"
                   placeholder="Enter your password" />
            <span asp-validation-for="Password" class="text-danger" style="font-size:12px"></span>
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="fas fa-sign-in-alt me-2"></i>Sign In
        </button>
    </form>

    <div class="auth-link">
        Don't have an account?
        <a href="/Auth/Register">Create Account</a>
    </div>
</div>
