@model SpendSmart2.Models.Expense
@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Expense";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <h5>
                    <i class="fas fa-edit me-2" style="color:#4cc9f0"></i>
                    Edit Expense
                </h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" asp-controller="Expense"
                      asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label class="form-label fw-500">
                            <i class="fas fa-tag me-2" style="color:#4cc9f0"></i>
                            Expense Name
                        </label>
                        <input asp-for="Name"
                               class="form-control"
                               placeholder="e.g. Grocery Shopping" />
                        <span asp-validation-for="Name" class="text-danger" style="font-size:12px"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-500">
                            <i class="fas fa-list me-2" style="color:#4cc9f0"></i>
                            Category
                        </label>
                        <select asp-for="Category" class="form-select">
                            <option value="">-- Select Category --</option>
                            <option value="Food & Dining">🍔 Food & Dining</option>
                            <option value="Transport">🚗 Transport</option>
                            <option value="Shopping">🛍️ Shopping</option>
                            <option value="Entertainment">🎮 Entertainment</option>
                            <option value="Health">💊 Health</option>
                            <option value="Education">📚 Education</option>
                            <option value="Bills & Utilities">💡 Bills & Utilities</option>
                            <option value="Housing">🏠 Housing</option>
                            <option value="Other">📦 Other</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger" style="font-size:12px"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-500">
                            <i class="fas fa-money-bill me-2" style="color:#4cc9f0"></i>
                            Amount (₦)
                        </label>
                        <input asp-for="Amount"
                               class="form-control"
                               placeholder="0.00"
                               type="number"
                               step="0.01" />
                        <span asp-validation-for="Amount" class="text-danger" style="font-size:12px"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-500">
                            <i class="fas fa-calendar me-2" style="color:#4cc9f0"></i>
                            Date
                        </label>
                        <input asp-for="Date"
                               class="form-control"
                               type="date" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Update Expense
                        </button>
                        <a href="/Expense/Index" class="btn btn-secondary" style="border-radius:10px">
                            <i class="fas fa-arrow-left me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
